# ── 일짜곰 프론트엔드 환경 변수 ──
# 실제 값은 .env.local 에 넣는다(.gitignore 대상). 이 파일은 템플릿.

# 백엔드(FastAPI) 베이스 URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase (Google 로그인/세션). 비워 두면 프론트는 "개발 로그인" 모드로 동작한다.
#  - 개발 로그인 모드: 이메일/역할을 골라 dev:<email>:<role> 토큰을 백엔드로 보낸다.
#    백엔드도 DEV_AUTH=true(+ JWT 시크릿 없음)여야 키 없이 P1 슬라이스가 끝까지 동작한다.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (선택) 백엔드가 비어 있을 때 프론트 단독 데모용 목업을 강제로 켠다.
#  보통은 비워 둔다(백엔드가 인메모리/mock로 계약을 그대로 제공하므로 실제 호출을 권장).
NEXT_PUBLIC_USE_MOCKS=false
