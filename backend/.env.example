# 일짜곰 백엔드 환경 변수 예시 — 실제 값은 .env 에 채우고 절대 커밋하지 않는다.

# --- Supabase ---
# 비우면 인메모리 저장소(InMemoryStore)로 동작한다(로컬 개발/계약 검증용).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # 서버 전용(워커/관리). 클라이언트에 노출 금지.
SUPABASE_JWT_SECRET=              # Supabase JWT(HS256) 검증용 시크릿.

# --- Google AI (Gemini / Imagen) ---
# 비우면 AI 호출이 결정적 mock 응답으로 대체된다(키 없이도 계약 동작).
GOOGLE_API_KEY=
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_FLASH_LITE=gemini-2.5-flash-lite
GEMINI_EMBED_MODEL=gemini-embedding-001
IMAGEN_MODEL=imagen-4.0-generate-001

# --- 운영 ---
ADMIN_EMAILS=                     # 쉼표 구분 관리자 화이트리스트
ALLOWED_ORIGINS=http://localhost:3000   # CORS (쉼표 구분, 배포 시 프론트 도메인 추가)

# --- 실행 모드 / 영속화 ---
# APP_ENV: dev | test | prod.
#  - prod: Supabase 자격(SUPABASE_URL/SERVICE_ROLE_KEY)이 없으면 기동 거부(fail-closed).
#  - dev: 자격 없으면 인메모리 폴백(경고, 영속화 안 됨).
#  - test: 항상 인메모리 허용(conftest 가 자동 설정).
APP_ENV=dev
# ALLOW_IN_MEMORY: 자격이 있어도 인메모리를 강제 허용(테스트 전용). 운영 금지.
ALLOW_IN_MEMORY=false
# REDIS_URL: rate limit 확장(선택). 비우면 DB(Store) 기반 한도.
REDIS_URL=

# --- 배포(컨테이너) ---
PORT=8000                         # 호스팅이 주입(미설정 시 8000)
WEB_CONCURRENCY=2                 # uvicorn 워커 수(무상태 전제)

# --- 개발 인증 ---
# 코드 기본값은 false(보안). 로컬에서만 명시적으로 true 로 켠다.
# true 면 "Authorization: Bearer dev:<email>:<role>" 형식의 개발 토큰을 허용한다.
# 단, SUPABASE_JWT_SECRET 또는 SUPABASE_URL 이 설정되어 있으면(=운영) dev 토큰은 무시되고
# (fail-closed) 앱은 기동을 거부한다. 운영에서는 반드시 false.
DEV_AUTH=true
